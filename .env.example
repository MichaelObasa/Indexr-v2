# ===========================================
# Indexr Deployment - Environment Variables
# ===========================================
# Copy to .env in repo root. Required for forge script --broadcast.
# Never commit .env (it contains secrets).

# Required for deployment
PRIVATE_KEY=your_deployer_private_key_no_0x_prefix
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Optional: for on-chain verification after deploy
# ETHERSCAN_API_KEY=your_arbiscan_api_key
